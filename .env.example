# Apps run on these ports locally
API_PORT=3001
WEB_PORT=3000
ADMIN_PORT=3002

# Docker local infra (do not change for local dev)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=longnhan
DB_USERNAME=longnhan
DB_PASSWORD=longnhan

REDIS_HOST=localhost
REDIS_PORT=6379

# Maildev (fake SMTP for local dev — web UI at http://localhost:1080)
MAIL_PORT=1025
MAIL_CLIENT_PORT=1080
