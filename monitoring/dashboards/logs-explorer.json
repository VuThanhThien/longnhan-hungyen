{
  "annotations": { "list": [] },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "panels": [
    {
      "title": "Log Volume by Level",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
      "targets": [
        {
          "expr": "sum by (level) (count_over_time({project=\"longnhan\"} [1m]))",
          "legendFormat": "{{level}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "lineWidth": 1, "fillOpacity": 30, "drawStyle": "bars" }
        },
        "overrides": []
      }
    },
    {
      "title": "Log Stream",
      "type": "logs",
      "gridPos": { "h": 16, "w": 24, "x": 0, "y": 8 },
      "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
      "targets": [
        {
          "expr": "{project=\"longnhan\", service=~\"$service\"} |= \"$search\"",
          "refId": "A"
        }
      ],
      "options": {
        "showTime": true,
        "showLabels": true,
        "showCommonLabels": false,
        "wrapLogMessage": true,
        "prettifyLogMessage": true,
        "enableLogDetails": true,
        "sortOrder": "Descending"
      }
    }
  ],
  "schemaVersion": 39,
  "tags": ["longnhan", "logs"],
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": { "type": "loki", "uid": "grafanacloud-logs" },
        "query": "label_values({project=\"longnhan\"}, service)",
        "includeAll": true,
        "current": { "text": "All", "value": "$__all" },
        "multi": false
      },
      {
        "name": "search",
        "type": "textbox",
        "current": { "text": "", "value": "" }
      }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "timepicker": {},
  "timezone": "browser",
  "title": "Logs Explorer",
  "uid": "longnhan-logs-explorer"
}
