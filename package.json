{
  "name": "longnhantongtran",
  "private": true,
  "pnpm": {
    "ignoredBuiltDependencies": ["sharp", "unrs-resolver"]
  },
  "scripts": {
    "dev": "turbo dev",
    "dev:api": "pnpm --filter @longnhan/api dev",
    "dev:web": "pnpm --filter @longnhan/web dev",
    "dev:admin": "pnpm --filter @longnhan/admin dev",
    "build": "turbo build",
    "build:api": "pnpm --filter @longnhan/api build",
    "build:web": "pnpm --filter @longnhan/web build",
    "build:admin": "pnpm --filter @longnhan/admin build",
    "lint": "turbo lint",
    "lint:api": "pnpm --filter @longnhan/api lint",
    "lint:web": "pnpm --filter @longnhan/web lint",
    "lint:admin": "pnpm --filter @longnhan/admin lint",
    "format": "turbo run format",
    "format:api": "pnpm --filter @longnhan/api format",
    "format:web": "pnpm --filter @longnhan/web format",
    "format:admin": "pnpm --filter @longnhan/admin format",
    "type-check": "turbo type-check",
    "type-check:api": "pnpm --filter @longnhan/api type-check",
    "type-check:web": "pnpm --filter @longnhan/web type-check",
    "type-check:admin": "pnpm --filter @longnhan/admin type-check",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:reset": "docker compose down -v && docker compose up -d"
  },
  "devDependencies": {
    "turbo": "^2.5.0",
    "typescript": "^5.4.0"
  },
  "packageManager": "pnpm@10.32.1"
}
