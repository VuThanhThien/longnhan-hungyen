            {...buttonProps}
          >
            <ALargeSmall
              className="tiptap-button-icon"
              style={{ color: activeColor || undefined }}
            />
          </Button>
        </PopoverTrigger>
        <PopoverContent className="tiptap-color-text-popover-content">
          <Card>
            <CardBody>
              <CardItemGroup
                orientation="horizontal"
