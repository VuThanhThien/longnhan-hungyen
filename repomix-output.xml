            </div>
            <button
              type="button"
              onClick={next}
              aria-label="Slide tiếp"
              className="rounded-full p-1 text-(--brand-forest-muted) transition hover:text-(--brand-forest)"
            >
              <svg
                className="h-5 w-5"
                fill="none"
                stroke="currentColor"
                viewBox="0 0 24 24"
              >
                <path
                  strokeLinecap="round"
                  strokeLinejoin="round"
                  strokeWidth={2}
                  d="M9 5l7 7-7 7"
