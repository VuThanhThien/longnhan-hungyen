  PAID = 'paid',
  FAILED = 'failed',
}

export enum OrderStatus {
  PENDING = 'pending',
  CONFIRMED = 'confirmed',
  SHIPPING = 'shipping',
  DELIVERED = 'delivered',
  CANCELLED = 'cancelled',
}

@Entity('order')
@Index('IDX_order_created_at', ['createdAt'])
export class OrderEntity {
  constructor(data?: Partial<OrderEntity>) {
    Object.assign(this, data);
  }

