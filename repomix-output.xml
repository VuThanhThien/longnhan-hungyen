      expect(reflector.getAllAndOverride).toHaveBeenCalledTimes(2);
      expect(context.switchToHttp().getRequest).toHaveBeenCalledTimes(1);
      expect(authService.verifyAccessToken).toHaveBeenCalledTimes(1);
    });
  });
