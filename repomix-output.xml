@import 'tailwindcss';
@import '../components/articles/article-tiptap-content.css';

:root {
  /* Template palette */
  --palette-offwhite: #fdfdf9;
  --palette-pale-yellow: #fbef9c;
  --palette-vivid-yellow: #fee32b;
  --palette-olive: #877928;
  --palette-near-black: #201d18;

  /* Semantic tokens */
  --background: var(--palette-offwhite);
  --foreground: var(--palette-near-black);
  --surface: var(--palette-offwhite);
  --muted: var(--palette-pale-yellow);
  --muted-foreground: var(--palette-olive);
  --border: color-mix(in srgb, var(--palette-olive) 20%, transparent);
  --ring: var(--palette-near-black);
  --primary: var(--palette-near-black);
  --primary-foreground: var(--palette-offwhite);
  --accent: var(--palette-vivid-yellow);
  --accent-foreground: var(--palette-near-black);

  /* Legacy brand tokens used across UI (mapped to new palette) */
  --brand-cream: var(--background);
  --brand-forest: var(--foreground);
  --brand-forest-soft: var(--muted-foreground);
  --brand-forest-muted: var(--muted-foreground);
  --brand-leaf: var(--primary);
  --brand-gold: var(--accent);
  --brand-gold-dark: var(--palette-olive);

  --font-display: var(--font-seagull), 'Times New Roman', serif;
}

@theme inline {
  --color-background: var(--background);
  --color-foreground: var(--foreground);
  --color-surface: var(--surface);
  --color-muted: var(--muted);
  --color-muted-foreground: var(--muted-foreground);
  --color-border: var(--border);
  --color-ring: var(--ring);
  --color-primary: var(--primary);
  --color-primary-foreground: var(--primary-foreground);
  --color-accent: var(--accent);
  --color-accent-foreground: var(--accent-foreground);
  --font-sans: var(--font-geist-sans);
  --font-mono: var(--font-geist-mono);
}

body {
  background-color: var(--background);
  background-repeat: repeat;
  background-size: 420px auto;
  color: var(--foreground);
  font-family: var(--font-geist-sans), system-ui, sans-serif;
  font-weight: 400;
}

.landing-page {
  position: relative;
  isolation: isolate;
}

.landing-page::before {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 0;
  background-repeat: repeat;
  background-size: 420px auto;
  opacity: 0.14;
}

.landing-page > * {
  position: relative;
  z-index: 1;
}

.landing-section {
  position: relative;
  isolation: isolate;
}

.landing-section::before {
  content: '';
  position: absolute;
  inset: 0;
  pointer-events: none;
  z-index: 2;
  background-repeat: no-repeat;
  opacity: 0.22;
  filter: saturate(1.05) contrast(1.05);
  mix-blend-mode: multiply;
}

.landing-section > * {
  position: relative;
  z-index: 1;
}

.landing-section--decor-hero::before {
  background-image: url('/bg-body-5.png');
  background-size: clamp(220px, 26vw, 420px) auto;
  background-position: top 18px right -12px;
  opacity: 0.42;
}

.landing-section--decor-story::before {
  background-image: url('/bg-body-1.png');
  background-size: clamp(240px, 30vw, 520px) auto;
  background-position: center left -28px;
  opacity: 0.38;
}

.landing-section--decor-cta::before {
  background-image: url('/bg-body-2.png');
  background-size: clamp(240px, 28vw, 520px) auto;
  background-position: bottom 12px right -16px;
  opacity: 0.34;
}

/* FAQ: same lotus strip as story preset, anchored right so it reads as a vertical accent */
.landing-section--decor-faq::before {
  background-image: url('/bg-body-1.png');
  background-size: clamp(200px, 26vw, 420px) auto;
  background-position: top 10% right -20px;
  opacity: 0.36;
}

.landing-heading {
  font-family: var(--font-display), ui-serif, 'Georgia', serif;
}
</file>

