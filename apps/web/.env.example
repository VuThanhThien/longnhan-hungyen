## ============================================
## Web app environment variables
## Copy this file to .env and fill real values
## ============================================

## API base URLs
API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

## Public site URL (metadata, sitemap, canonical)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

## Cloudinary (public cloud name for image loader)
NEXT_PUBLIC_CLOUDINARY_CLOUD=your-cloud-name

## Optional: only needed if web app uploads to Cloudinary directly
# CLOUDINARY_API_KEY=your-cloudinary-api-key
# CLOUDINARY_API_SECRET=your-cloudinary-api-secret
NEXT_PUBLIC_ENABLE_SW=false
